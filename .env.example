# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Mailbox (only needed if adapter = imap) ─────────────────────────────────
MAILBOX_USER=your-email@example.com
MAILBOX_PASS=your-app-password-here

# ── Gmail API (only needed if adapter = gmail) ───────────────────────────────
# Path to a service-account JSON key downloaded from Google Cloud Console
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/gmail_service_account.json

# ── Google Sheets (only needed if output adapter = google_sheets) ────────────
# GOOGLE_SHEETS_SERVICE_ACCOUNT=./credentials/sheets_service_account.json

# ── Microsoft Graph / Outlook (only needed if adapter = outlook) ─────────────
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
